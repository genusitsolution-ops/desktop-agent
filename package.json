{
  "name": "remoteconnect-agent",
  "version": "1.0.0",
  "description": "RemoteConnect Pro — Desktop Agent",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.genusitsolution.remoteconnect",
    "productName": "RemoteConnect Agent",
    "copyright": "Copyright © 2025 GenusIT Solution",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": ["src/**/*", "assets/**/*", "node_modules/**/*"],
    "extraResources": [],
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "robot.js": "^0.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
